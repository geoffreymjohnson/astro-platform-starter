---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You | Achillea Built">
  <section class="mx-auto max-w-2xl py-12 sm:py-16">
    <div class="rounded-2xl border border-black/10 bg-white/70 p-8 shadow-sm backdrop-blur-sm reveal">
      <p class="mb-3 text-sm font-semibold tracking-[0.14em] uppercase opacity-70">
        Achillea Built LLC
      </p>
      <h1 class="mb-6">Thank You</h1>
      <p class="text-lg leading-8">
        Your estimate request has been submitted. We’ll review it and follow up
        if the project looks like a good fit.
      </p>

      <p class="mt-8">
        <a href="/" class="btn">Return Home</a>
      </p>
    </div>
  </section>
</Layout>